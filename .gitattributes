# Force LF line endings for every text file in the repository, on every
# platform. This overrides users' `core.autocrlf` settings so a Windows
# checkout still gets LF in the working tree.
#
# The `text=auto` directive tells git to auto-detect text vs binary and
# apply the platform-independent LF normalization.
* text=auto eol=lf

# Explicit LF for common text formats — belt-and-braces in case a file
# lands with an unusual extension.
*.go        text eol=lf
*.mod       text eol=lf
*.sum       text eol=lf
*.md        text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.conf      text eol=lf
*.c         text eol=lf
*.h         text eol=lf
Makefile    text eol=lf
Dockerfile  text eol=lf

# Explicit binary — never touch line endings on these.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.pdf       binary
*.so        binary
*.a         binary
*.o         binary
